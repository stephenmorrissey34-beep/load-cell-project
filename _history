n\n// ===== Calibration (your original dataset) =====\nlet offset = 8957000\nlet scale = 430\n\n// ===== LED pins =====\nlet led100 = DigitalPin.P1\nlet led300 = DigitalPin.P19\nlet led500 = DigitalPin.P12\n\n// ===== Stability system =====\nlet lastWeight = 0\nlet stableCounter = 0\nlet wasStable = false\n\nlet threshold = 20\nlet stabilityRange = 2\nlet stableRequired = 5\n\n// =====================\n// HX711 setup\n// =====================\nHX711.SetPIN_DOUT(DigitalPin.P0)\nHX711.SetPIN_SCK(DigitalPin.P8)\nHX711.begin()\n\n// =====================\n// Serial setup\n// =====================\nserial.redirect(\n    SerialPin.USB_TX,\n    SerialPin.USB_RX,\n    BaudRate.BaudRate115200\n)\n\nserial.writeLine(\"=== HX711 Smart Scale ===\")\nserial.writeLine(\"LED: 100g / 300g / 500g\")\nserial.writeLine(\"Double beep = stable weight\")\nserial.writeLine(\"--------------------------------\")\n\nbasic.pause(2000)\n\n// =====================\n// MAIN LOOP\n// =====================\nbasic.forever(function () {\n    raw = HX711.read_average(25)\n\n    let weight = (raw - offset) / scale\n    let weightRounded = Math.round(weight * 10) / 10\n\n    // =====================\n    // SERIAL OUTPUT\n    // =====================\n    serial.writeString(\"Weight: \")\n    serial.writeNumber(weightRounded)\n    serial.writeString(\" g | Raw: \")\n    serial.writeNumber(raw)\n    serial.writeLine(\"\")\n\n    // =====================\n    // DISPLAY\n    // =====================\n    basic.showNumber(Math.round(weight))\n\n    // =====================\n    // LED INDICATORS\n    // =====================\n    pins.digitalWritePin(led100, weight >= 100 ? 1 : 0)\n    pins.digitalWritePin(led300, weight >= 300 ? 1 : 0)\n    pins.digitalWritePin(led500, weight >= 500 ? 1 : 0)\n\n    // =====================\n    // STABILITY DETECTION\n    // =====================\n    if (weight > threshold) {\n\n        if (Math.abs(weight - lastWeight) < stabilityRange) {\n            stableCounter += 1\n        } else {\n            stableCounter = 0\n        }\n\n        if (stableCounter >= stableRequired && !wasStable) {\n            wasStable = true\n\n            // DOUBLE BEEP 🎵🎵\n            music.playTone(988, 100)\n            basic.pause(80)\n            music.playTone(1318, 120)\n        }\n\n    } else {\n        stableCounter = 0\n        wasStable = false\n    }\n\n    lastWeight = weight\n\n    basic.pause(200)\n})","README.md":"","pxt.json":"{\n    \"name\": \"load cell project\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"pxt-HX711\": \"github:daferdur/pxt-myHX711#v1.0.18\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1776858198008,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"oSO_[h+0lKqXC=@-rEP7\">raw</variable><variable id=\"1Ko6m62DA)Xol7`^UkI*\">weight</variable><variable id=\"CxaA3ez!n`oUcTWnHk3q\">offset</variable><variable id=\"Ew{qFSyGij*Fp9@K$QV}\">scale</variable><variable id=\"4KOlLI}Y9b,CHIv,yjkT\">weightRounded</variable><variable id=\"[!Dh868T$M^tD?GmWTQ;\">led100</variable><variable id=\"n|CFq4;t5T!G8z[XWx|p\">led300</variable><variable id=\"=:hgtUGL1ngn,S*RXZNy\">led500</variable><variable id=\"0`p0E70FXf:,Z{JS~GDN\">threshold</variable><variable id=\"}Y+}K]r2Li-eYr,5:9|_\">stabilityRange</variable><variable id=\"6MR[9dL,4/`e7okjE7,K\">stableRequired</variable></variables><comment x=\"1295.75\" y=\"20\" w=\"280\" h=\"120\">\n===== Stability system =====\n</comment><block type=\"pxt-on-start\" x=\"20\" y=\"20\"><statement name=\"HANDLER\"><block type=\"variables_set\"><field name=\"VAR\" id=\"CxaA3ez!n`oUcTWnHk3q\">offset</field><comment pinned=\"false\" h=\"80\" w=\"160\">===== Calibration (your original 100g–800g dataset) ===