r(weightRounded)\n    serial.writeString(\" g | Raw: \")\n    serial.writeNumber(raw)\n    serial.writeLine(\"\")\n\n    // Display\n    basic.showNumber(Math.round(weight))\n\n    // Graph\n    led.plotBarGraph(weight, 1000)\n\n    basic.pause(500)\n})","README.md":"","pxt.json":"{\n    \"name\": \"load cell project\",\n    \"description\": \"\",\n    \"dependencies\": {\n        \"core\": \"*\",\n        \"radio\": \"*\",\n        \"microphone\": \"*\",\n        \"pxt-HX711\": \"github:daferdur/pxt-myHX711#v1.0.18\"\n    },\n    \"files\": [\n        \"main.blocks\",\n        \"main.ts\",\n        \"README.md\"\n    ],\n    \"preferredEditor\": \"tsprj\"\n}\n"}},{"timestamp":1776799060627,"editorVersion":"8.0.21","text":{"main.blocks":"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"8p|LhQBNE-iUb6yozfdI\">offset</variable><variable id=\"F;.11:,Sv@v8)1#T)oNZ\">raw</variable><variable id=\"ed7V8q[,eFGbRl)BdHq?\">weight</variable><variable id=\"gP;.;^hlrBc^}/kK~Vvr\">scale</variable><variable id=\"(`J-cHRso8X:]07vTy0j\">weightRounded</variable><variable id=\")}*L0XOG^U[r:~D1(2Ce\">threshold</variable><variable id=\"?9csvF9ry18^pd(g9tTb\">stabilityRange</variable><variable id=\"cVn#gF|%n~WoC*`oO`^M\">stableRequired</variable></variables><block type=\"pxt-on-start\" x=\"0\" y=\"0\"><statement name=\"HANDLER\"><block type=\"variables_set\"><field name=\"VAR\" id=\"8p|LhQBNE-iUb6yozfdI\">offset</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">8957000</field></shadow></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\"gP;.;^hlrBc^}/kK~Vvr\">scale</field><value name=\"VALUE\"><shadow type=\"math_number\"><field name=\"NUM\">430</field></shadow></value><next><block type=\"variables_set\"><field name=\"VAR\" id=\")}*L0XOG^U[r:~D1(2Ce\">threshold</field><comment pinned=\"false\" h=\"80\" w=\"160\">minimum weight to consider \"loaded\"</comment><value name=\"VALUE\"><shadow type=\"math_number\"><f