es":[{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":2336,"diffs":[[1,""]]}]}]},{"timestamp":1776799194757,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":1,"diffs":[[1,""]]}]}]},{"timestamp":1776800456400,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":161,"diffs":[[1,"\n"]]}]}]},{"timestamp":1776800463172,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"main.ts","patch":[{"start1":28,"length1":0,"diffs":[[1,"    pins.digitalWritePin(DigitalPin.P1, 0)\n"]]},{"start1":114,"length1":0,"diffs":[[1,"    pins.digitalWritePin(DigitalPin.P12, 0)\n"]]}]}]},{"timestamp":1776800598392,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":0,"diffs":[[1,"basic.forever(function () {\n    pins.digitalWritePin(DigitalPin.P6, 0)\n})\nlet raw = 0\n\n// ===== Calibration (your original dataset) =====\nlet offset = 8957000\nlet scale = 430\n\n// ===== LED pins =====\nlet led100 = DigitalPin.P1\nlet led300 = DigitalPin.P19\nlet led500 = DigitalPin.P12\n\n// ===== Stability system =====\nlet lastWeight = 0\nlet stableCounter = 0\nlet wasStable = false\n\nlet threshold = 20\nlet stabilityRange = 2\nlet stableRequired = 5\n\n// =====================\n// HX711 setup\n// =====================\nHX711.SetPIN_DOUT(DigitalPin.P0)\nHX711.SetPIN_SCK(DigitalPin.P8)\nHX711.begin()\n\n// =====================\n// Serial setup\n// =====================\nserial.redirect(\n    SerialPin.USB_TX,\n    SerialPin.USB_RX,\n    BaudRate.BaudRate115200\n)\n\nserial.writeLine(\"=== HX711 Smart Scale ===\")\nserial.writeLine(\"LED: 100g / 300g / 500g\")\nserial.writeLine(\"Double beep = stable weight\")\nserial.writeLine(\"--------------------------------\")\n\nbasic.pause(2000)\n\n// =====================\n// MAIN LOOP\n// =====================\nbasic.forever(function () {\n    raw = HX711.read_average(25)\n\n    let weight = (raw - offset) / scale\n    let weightRounded = Math.round(weight * 10) / 10\n\n    // =====================\n    // SERIAL OUTPUT\n    // =====================\n    serial.writeString(\"Weight: \")\n    serial.writeNumber(weightRounded)\n    serial.writeString(\" g | Raw: \")\n    serial.writeNumber(raw)\n    serial.writeLine(\"\")\n\n    // =====================\n    // DISPLAY\n    // =====================\n    basic.showNumber(Math.round(weight))\n\n    // =====================\n    // LED INDICATORS\n    // =====================\n    pins.digitalWritePin(led100, weight >= 100 ? 1 : 0)\n    pins.digitalWritePin(led300, weight >= 300 ? 1 : 0)\n    pins.digitalWritePin(led500, weight >= 500 ? 1 : 0)\n\n    // =====================\n    // STABILITY DETECTION\n    // =====================\n    if (weight > threshold) {\n\n        if (Math.abs(weight - lastWeight) < stabilityRange) {\n            stableCounter += 1\n        } else {\n            stableCounter = 0\n        }\n\n        if (stableCounter >= stableRequired && !wasStable) {\n            wasStable = true\n\n            // DOUBLE BEEP 🎵🎵\n            music.playTone(988, 100)\n            basic.pause(80)\n            music.playTone(1318, 120)\n        }\n\n    } else {\n        stableCounter = 0\n        wasStable = false\n    }\n\n    lastWeight = weight\n\n    basic.pause(200)\n})"]]}]}]},{"timestamp":1776801210439,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"main.ts","patch":[{"start1":0,"length1":2290,"diffs":[[1,""]]}]}]},{"timestamp":1776801214288,"editorVersion":"8.0.21","changes":[{"type":"edited","filename":"main.blocks","patch":[{"start1":0,"length1":2860,"diffs":[[1,"<xml xmlns=\"https://developers.google.com/blockly/xml\"><variables><variable id=\"8p|LhQBNE-iUb6yozfdI\">offset</variable><variable id=\"F;.11:,Sv@v8)1#T)oNZ\">raw</variable><variable id=\"ed7V8q[,eFGbRl)BdHq?\">weight</variable><variable id=\"gP;.;^hlrBc^}/kK~Vvr\">scale</variable><variable id=\